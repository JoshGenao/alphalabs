{
  "requirement": "SRS-ARCH-001",
  "core_runtime_language": "Rust",
  "strategy_api_language": "Python",
  "core_runtime_services": [
    {
      "name": "Types and Domain Models",
      "crate": "atp-types",
      "path": "crates/atp-types"
    },
    {
      "name": "Data Layer",
      "crate": "atp-data",
      "path": "crates/atp-data"
    },
    {
      "name": "Strategy Engine",
      "crate": "atp-strategy-engine",
      "path": "crates/atp-strategy-engine"
    },
    {
      "name": "Execution Engine",
      "crate": "atp-execution",
      "path": "crates/atp-execution"
    },
    {
      "name": "Internal Simulation Engine",
      "crate": "atp-simulation",
      "path": "crates/atp-simulation"
    },
    {
      "name": "Market Data Subscription Manager",
      "crate": "atp-market-data",
      "path": "crates/atp-market-data"
    },
    {
      "name": "Strategy Orchestrator",
      "crate": "atp-orchestrator",
      "path": "crates/atp-orchestrator"
    },
    {
      "name": "Broker and Data Provider Adapters",
      "crate": "atp-adapters",
      "path": "crates/atp-adapters"
    },
    {
      "name": "Factor Pipeline Runtime",
      "crate": "atp-factor-pipeline",
      "path": "crates/atp-factor-pipeline"
    },
    {
      "name": "Notification Dispatcher",
      "crate": "atp-notification",
      "path": "crates/atp-notification"
    }
  ],
  "dependency_direction": {
    "requirement": "SRS-ARCH-002",
    "flow": [
      "atp-types",
      "atp-data",
      "atp-strategy-engine",
      "atp-execution / atp-simulation",
      "atp-adapters"
    ],
    "enforced_crates": [
      {
        "crate": "atp-types",
        "path": "crates/atp-types",
        "allowed_dependencies": []
      },
      {
        "crate": "atp-data",
        "path": "crates/atp-data",
        "allowed_dependencies": [
          "atp-types"
        ]
      },
      {
        "crate": "atp-strategy-engine",
        "path": "crates/atp-strategy-engine",
        "allowed_dependencies": [
          "atp-data",
          "atp-types"
        ]
      },
      {
        "crate": "atp-execution",
        "path": "crates/atp-execution",
        "allowed_dependencies": [
          "atp-data",
          "atp-strategy-engine",
          "atp-types"
        ]
      },
      {
        "crate": "atp-simulation",
        "path": "crates/atp-simulation",
        "allowed_dependencies": [
          "atp-data",
          "atp-strategy-engine",
          "atp-types"
        ]
      },
      {
        "crate": "atp-adapters",
        "path": "crates/atp-adapters",
        "allowed_dependencies": [
          "atp-types"
        ]
      }
    ],
    "sidecar_crates": [
      {
        "crate": "atp-market-data",
        "path": "crates/atp-market-data",
        "allowed_dependencies": [
          "atp-types"
        ]
      },
      {
        "crate": "atp-factor-pipeline",
        "path": "crates/atp-factor-pipeline",
        "allowed_dependencies": [
          "atp-data",
          "atp-types"
        ]
      },
      {
        "crate": "atp-notification",
        "path": "crates/atp-notification",
        "allowed_dependencies": [
          "atp-types"
        ]
      }
    ],
    "lower_layer_scan_crates": [
      "atp-types",
      "atp-data",
      "atp-strategy-engine",
      "atp-execution",
      "atp-simulation",
      "atp-market-data",
      "atp-factor-pipeline",
      "atp-notification"
    ],
    "forbidden_imports": [
      {
        "token": "atp_orchestrator",
        "reason": "lower layers must not call the Strategy Orchestrator"
      },
      {
        "token": "atp_api",
        "reason": "lower layers must not call the dashboard/API package"
      },
      {
        "token": "atp_dashboard",
        "reason": "lower layers must not call dashboard modules"
      },
      {
        "token": "atp_adapters",
        "reason": "vendor adapter implementations must stay behind the adapter boundary",
        "allowed_crates": [
          "atp-adapters"
        ]
      },
      {
        "token": "ib_gateway",
        "reason": "Interactive Brokers integration belongs in adapter modules",
        "allowed_crates": [
          "atp-adapters"
        ]
      },
      {
        "token": "interactive_brokers",
        "reason": "Interactive Brokers integration belongs in adapter modules",
        "allowed_crates": [
          "atp-adapters"
        ]
      },
      {
        "token": "databento",
        "reason": "Databento integration belongs in adapter modules",
        "allowed_crates": [
          "atp-adapters"
        ]
      },
      {
        "token": "sharadar",
        "reason": "Sharadar integration belongs in adapter modules",
        "allowed_crates": [
          "atp-adapters"
        ]
      }
    ]
  },
  "adapter_isolation": {
    "requirement": "SRS-ARCH-003",
    "adapter_crate": {
      "crate": "atp-adapters",
      "path": "crates/atp-adapters"
    },
    "required_traits": [
      "BrokerageAdapter",
      "MarketDataAdapter",
      "HistoricalDataAdapter",
      "DataProviderAdapter",
      "BulkEquityDataProvider",
      "FundamentalDataProvider",
      "OptionsDataProvider",
      "UserParquetDataProvider",
      "AlternativeDataProvider"
    ],
    "required_providers": [
      "InteractiveBrokersAdapter",
      "DatabentoAdapter",
      "SharadarAdapter",
      "UserParquetAdapter",
      "FutureStubProvider"
    ],
    "core_vendor_free_crates": [
      "atp-types",
      "atp-data",
      "atp-strategy-engine",
      "atp-execution",
      "atp-simulation",
      "atp-market-data",
      "atp-orchestrator",
      "atp-factor-pipeline",
      "atp-notification"
    ],
    "forbidden_vendor_imports": [
      {
        "token": "ib_gateway",
        "reason": "Interactive Brokers SDK usage belongs behind the adapter interface"
      },
      {
        "token": "interactive_brokers",
        "reason": "Interactive Brokers SDK usage belongs behind the adapter interface"
      },
      {
        "token": "ibapi",
        "reason": "Interactive Brokers SDK usage belongs behind the adapter interface"
      },
      {
        "token": "databento",
        "reason": "Databento SDK usage belongs behind the adapter interface"
      },
      {
        "token": "sharadar",
        "reason": "Sharadar access belongs behind the adapter interface"
      }
    ]
  },
  "strategy_api": {
    "package": "atp_strategy",
    "path": "python/atp_strategy",
    "required_exports": [
      "ATR",
      "AssetClass",
      "AssetClassViolation",
      "Bar",
      "BarConsolidator",
      "BollingerBands",
      "EMA",
      "HistoricalData",
      "Indicator",
      "MACD",
      "OrderEvent",
      "OrderEventType",
      "OrderHandle",
      "OrderRequest",
      "OrderSide",
      "OrderType",
      "RSI",
      "RangeBarBuilder",
      "RenkoBuilder",
      "SMA",
      "ScheduleHandle",
      "Scheduler",
      "StaticTradingCalendar",
      "Strategy",
      "StrategyAPIError",
      "StrategyConfig",
      "StrategyContext",
      "TradingCalendar",
      "WarmupNotComplete"
    ]
  },
  "rest_api": {
    "package": "atp_api",
    "path": "python/atp_api",
    "required_capabilities": [
      "STRATEGY_LIFECYCLE",
      "LIVE_DESIGNATION",
      "KILL_SWITCH",
      "HOT_SWAP",
      "BACKTEST_LAUNCH",
      "BACKTEST_QUERY",
      "RESERVOIR_RANKING",
      "WATCHLIST_CONFIG",
      "SYSTEM_STATUS",
      "LOGS",
      "ALERTS"
    ],
    "openapi_snapshot": "python/atp_api/openapi.json",
    "bind_host": "127.0.0.1",
    "auth_model": "local-single-user"
  },
  "deployment": {
    "requirement": "SRS-ARCH-004",
    "target": "Phase 1 Proxmox Ubuntu VM",
    "compose_file": "docker-compose.yml",
    "phase1_profile": "phase1",
    "env_example": ".env.example",
    "deployment_doc": "docs/DEPLOYMENT.md",
    "required_services": [
      "phase1-orchestrator",
      "phase1-execution-engine",
      "phase1-strategy-engine",
      "phase1-simulation-engine",
      "phase1-market-data",
      "phase1-data-layer",
      "phase1-factor-pipeline",
      "phase1-notification-dispatcher",
      "phase1-dashboard-api",
      "phase1-jupyter",
      "phase1-ib-gateway",
      "phase1-strategy-runtime"
    ],
    "required_dockerfiles": [
      "docker/core-runtime.Dockerfile",
      "docker/strategy-python.Dockerfile",
      "docker/dashboard-api.Dockerfile",
      "docker/jupyter.Dockerfile",
      "docker/ib-gateway.Dockerfile"
    ],
    "required_env_vars": [
      "ATP_ENV",
      "ATP_IB_HOST",
      "ATP_IB_LIVE_PORT",
      "ATP_IB_PAPER_PORT",
      "ATP_MARKET_DATA_LINE_LIMIT",
      "ATP_SSD_DATA_DIR",
      "ATP_NAS_DATA_DIR",
      "ATP_SMTP_API_KEY",
      "ATP_SMS_API_KEY",
      "DATABENTO_API_KEY",
      "SHARADAR_API_KEY",
      "ATP_LIVE_STRATEGY_MEM_MB",
      "ATP_LIVE_STRATEGY_CPU",
      "ATP_PAPER_STRATEGY_MEM_MB",
      "ATP_PAPER_STRATEGY_CPU",
      "ATP_HOST_MEMORY_SAFETY_MARGIN_MB"
    ],
    "required_volumes": [
      {
        "name": "atp_ssd",
        "env": "ATP_SSD_DATA_DIR",
        "tier": "primary"
      },
      {
        "name": "atp_nas",
        "env": "ATP_NAS_DATA_DIR",
        "tier": "archive"
      }
    ],
    "dashboard_bind_host": "127.0.0.1",
    "portability_doc_keywords": [
      "Phase 1",
      "Proxmox",
      "cloud VPS",
      "future target",
      "portability constraints"
    ]
  },
  "configuration": {
    "requirement": "SRS-ARCH-005",
    "package": "atp_config",
    "path": "python/atp_config",
    "categories": [
      "credentials",
      "storage_paths",
      "ib_account",
      "market_data_limits",
      "resource_limits",
      "notification_channels"
    ],
    "placeholder_value": "placeholder-set-in-environment",
    "production_envs": [
      "staging",
      "production"
    ],
    "keys": [
      {
        "name": "ATP_ENV",
        "category": "ib_account",
        "type": "enum",
        "validator": {
          "choices": [
            "development",
            "staging",
            "production"
          ]
        },
        "default": "development",
        "secret": false,
        "srs_trace": [
          "SRS-ARCH-005",
          "SRS-ARCH-004"
        ]
      },
      {
        "name": "ATP_IB_HOST",
        "category": "ib_account",
        "type": "host",
        "validator": {
          "non_empty": true
        },
        "default": "127.0.0.1",
        "secret": false,
        "srs_trace": [
          "SRS-EXE-006",
          "SyRS:IF-1"
        ]
      },
      {
        "name": "ATP_IB_LIVE_PORT",
        "category": "ib_account",
        "type": "int",
        "validator": {
          "min": 1,
          "max": 65535
        },
        "default": "4001",
        "secret": false,
        "srs_trace": [
          "SRS-EXE-006",
          "SyRS:AC-15"
        ]
      },
      {
        "name": "ATP_IB_PAPER_PORT",
        "category": "ib_account",
        "type": "int",
        "validator": {
          "min": 1,
          "max": 65535
        },
        "default": "4002",
        "secret": false,
        "srs_trace": [
          "SRS-EXE-006",
          "SyRS:AC-15"
        ]
      },
      {
        "name": "ATP_MARKET_DATA_LINE_LIMIT",
        "category": "market_data_limits",
        "type": "int",
        "validator": {
          "min": 1,
          "max": 10000
        },
        "default": "100",
        "secret": false,
        "srs_trace": [
          "SRS-MD-002",
          "SyRS:SYS-70"
        ]
      },
      {
        "name": "ATP_SSD_DATA_DIR",
        "category": "storage_paths",
        "type": "path",
        "validator": {
          "non_empty": true,
          "absolute": true
        },
        "default": "/var/lib/atp/ssd",
        "secret": false,
        "srs_trace": [
          "SRS-DATA-008",
          "SyRS:SYS-67"
        ]
      },
      {
        "name": "ATP_NAS_DATA_DIR",
        "category": "storage_paths",
        "type": "path",
        "validator": {
          "non_empty": true,
          "absolute": true
        },
        "default": "/var/lib/atp/nas",
        "secret": false,
        "srs_trace": [
          "SRS-DATA-008",
          "SRS-DATA-009"
        ]
      },
      {
        "name": "ATP_SMTP_API_KEY",
        "category": "notification_channels",
        "type": "secret",
        "validator": {
          "non_empty": true
        },
        "default": "placeholder-set-in-environment",
        "secret": true,
        "srs_trace": [
          "SRS-NOTIF-001",
          "NFR-S4",
          "StRS:SN-1.12"
        ]
      },
      {
        "name": "ATP_SMS_API_KEY",
        "category": "notification_channels",
        "type": "secret",
        "validator": {
          "non_empty": true
        },
        "default": "placeholder-set-in-environment",
        "secret": true,
        "srs_trace": [
          "SRS-NOTIF-001",
          "NFR-S4",
          "StRS:SN-1.12"
        ]
      },
      {
        "name": "DATABENTO_API_KEY",
        "category": "credentials",
        "type": "secret",
        "validator": {
          "non_empty": true
        },
        "default": "placeholder-set-in-environment",
        "secret": true,
        "srs_trace": [
          "SRS-DATA-001",
          "NFR-S1"
        ]
      },
      {
        "name": "SHARADAR_API_KEY",
        "category": "credentials",
        "type": "secret",
        "validator": {
          "non_empty": true
        },
        "default": "placeholder-set-in-environment",
        "secret": true,
        "srs_trace": [
          "SRS-DATA-005",
          "NFR-S1"
        ]
      },
      {
        "name": "ATP_LIVE_STRATEGY_MEM_MB",
        "category": "resource_limits",
        "type": "int",
        "validator": {
          "min": 64,
          "max": 65536
        },
        "default": "512",
        "secret": false,
        "srs_trace": [
          "SRS-ORCH-002",
          "SyRS:SYS-11",
          "SyRS:SYS-57"
        ]
      },
      {
        "name": "ATP_LIVE_STRATEGY_CPU",
        "category": "resource_limits",
        "type": "float",
        "validator": {
          "min": 0.05,
          "max": 16.0
        },
        "default": "0.25",
        "secret": false,
        "srs_trace": [
          "SRS-ORCH-002",
          "SyRS:SYS-11"
        ]
      },
      {
        "name": "ATP_PAPER_STRATEGY_MEM_MB",
        "category": "resource_limits",
        "type": "int",
        "validator": {
          "min": 64,
          "max": 65536
        },
        "default": "300",
        "secret": false,
        "srs_trace": [
          "SRS-ORCH-002",
          "SyRS:SYS-11"
        ]
      },
      {
        "name": "ATP_PAPER_STRATEGY_CPU",
        "category": "resource_limits",
        "type": "float",
        "validator": {
          "min": 0.05,
          "max": 16.0
        },
        "default": "0.10",
        "secret": false,
        "srs_trace": [
          "SRS-ORCH-002",
          "SyRS:SYS-11"
        ]
      },
      {
        "name": "ATP_HOST_MEMORY_SAFETY_MARGIN_MB",
        "category": "resource_limits",
        "type": "int",
        "validator": {
          "min": 256,
          "max": 1048576
        },
        "default": "2048",
        "secret": false,
        "srs_trace": [
          "SRS-ORCH-003",
          "SyRS:SYS-57",
          "SyRS:SYS-58"
        ]
      }
    ]
  }
}
