    "asyncapi_snapshot": "python/atp_ws/asyncapi.json",
    "bind_host": "127.0.0.1",
    "auth_model": "local-single-user",
    "ws_path": "/ws/v1",
    "max_refresh_seconds": 5
  },
  "cli": {
    "package": "atp_cli",
    "path": "python/atp_cli",
    "required_groups": [
      "kill-switch",
      "strategy",
      "live",
      "hot-swap",
      "readiness",
      "admin"
