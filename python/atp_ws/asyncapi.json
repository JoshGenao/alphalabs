{
  "asyncapi": "2.6.0",
  "channels": {
    "/ws/v1/_control": {
      "description": "Multiplexed client-to-server control plane: SUBSCRIBE, UNSUBSCRIBE, and HEARTBEAT_PING. Server replies with ACK / HEARTBEAT_PONG / ERROR over the same socket.",
      "publish": {
        "message": {
          "oneOf": [
            {
              "contentType": "application/json",
              "name": "SUBSCRIBE_command",
              "payload": {
                "additionalProperties": true,
                "properties": {
                  "channels": {
                    "type": "string"
                  },
                  "type": {
                    "const": "SUBSCRIBE"
                  }
                },
                "required": [
                  "type",
                  "channels"
                ],
                "type": "object"
              },
              "summary": "Subscribe to one or more event channels on the same socket.",
              "tags": [
                {
                  "name": "SUBSCRIBE"
                }
              ],
              "title": "Subscribe to one or more event channels on the same socket.",
              "x-direction": "CLIENT_TO_SERVER",
              "x-response-message": "ACK",
              "x-srs-refs": [
                "SRS-UI-001",
                "SRS-UI-002",
                "SRS-UI-003"
              ]
            },
            {
              "contentType": "application/json",
              "name": "UNSUBSCRIBE_command",
              "payload": {
                "additionalProperties": true,
                "properties": {
                  "channels": {
                    "type": "string"
                  },
                  "type": {
                    "const": "UNSUBSCRIBE"
                  }
                },
                "required": [
                  "type",
                  "channels"
                ],
                "type": "object"
              },
              "summary": "Stop receiving events for one or more previously subscribed channels.",
              "tags": [
                {
                  "name": "UNSUBSCRIBE"
                }
              ],
              "title": "Stop receiving events for one or more previously subscribed channels.",
              "x-direction": "CLIENT_TO_SERVER",
              "x-response-message": "ACK",
              "x-srs-refs": [
                "SRS-UI-001"
              ]
            },
            {
              "contentType": "application/json",
              "name": "HEARTBEAT_PING_command",
              "payload": {
                "additionalProperties": true,
                "properties": {
                  "nonce": {
                    "type": "string"
                  },
                  "type": {
                    "const": "HEARTBEAT_PING"
                  }
                },
                "required": [
                  "type",
                  "nonce"
                ],
                "type": "object"
              },
              "summary": "Connection liveness probe; server replies with HEARTBEAT_PONG.",
              "tags": [
                {
                  "name": "HEARTBEAT_PING"
                }
              ],
              "title": "Connection liveness probe; server replies with HEARTBEAT_PONG.",
              "x-direction": "CLIENT_TO_SERVER",
              "x-response-message": "HEARTBEAT_PONG",
              "x-srs-refs": [
                "SYS-39"
              ]
            }
          ]
        },
        "operationId": "client_command",
        "summary": "Submit a control-plane command."
      },
      "x-direction": "CLIENT_TO_SERVER"
    },
