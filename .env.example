# ATP Phase 1 deployment environment template (SRS-ARCH-004, SRS-ARCH-005).
# Copy to .env, fill in real secrets, then:
#   docker compose --env-file .env --profile phase1 up
#
# All secret values must be supplied at deployment time. The values in
# this template are placeholders only; ATP must not be deployed with
# them in production.
#
# ENCRYPTION AT REST (SRS-SEC-001): in staging/production the readiness gate
# REJECTS any catalogued secret (ATP_IB_ACCOUNT, ATP_SMTP_API_KEY,
# ATP_SMS_API_KEY, DATABENTO_API_KEY, SHARADAR_API_KEY) supplied as a real
# plaintext value here. Seal those secrets in the encrypted credential vault
# instead and point the stack at it — leave the placeholders below in place:
#   mkdir -p ./secrets && chmod 700 ./secrets
#   python -m atp_config.vault generate-key > ./secrets/atp.key && chmod 600 ./secrets/atp.key
#   ATP_IB_ACCOUNT=U... ATP_SMTP_API_KEY=... ATP_SMS_API_KEY=... \
#     ATP_VAULT_KEY_FILE=./secrets/atp.key python -m atp_config.vault seal ./secrets/atp.vault
# The compose stack bind-mounts ${ATP_SECRETS_DIR} read-only at
# /run/atp-secrets. For staging/production, set:
#   ATP_SECRETS_DIR=./secrets
#   ATP_VAULT_FILE=/run/atp-secrets/atp.vault
#   ATP_VAULT_KEY_FILE=/run/atp-secrets/atp.key
# Development (ATP_ENV=development) keeps plaintext-env flexibility: leave
# ATP_VAULT_FILE empty (as below) and use the placeholder secrets above.
ATP_SECRETS_DIR=./secrets
ATP_VAULT_FILE=
ATP_VAULT_KEY_FILE=

# Deployment selector. Use one of: development, staging, production.
ATP_ENV=development

# IB Gateway endpoint. Phase 1 runs IB Gateway co-located with the stack;
# ATP_IB_LIVE_PORT serves the IB live trading account, ATP_IB_PAPER_PORT
# serves the IB paper account that is reserved for adapter integration
# tests (SyRS AC-15).
ATP_IB_HOST=127.0.0.1
ATP_IB_LIVE_PORT=4001
ATP_IB_PAPER_PORT=4002

# IB brokerage account identifier (SRS-SEC-001 / NFR-S1). This is the
# sensitive brokerage credential per StRS C-3; it is redacted from all
# structured logs and may be sealed in the encrypted credential vault
# (python/atp_config/vault.py) instead of stored in plaintext here.
ATP_IB_ACCOUNT=placeholder-set-in-environment

# Market-data subscription line cap (SRS-MD-002).
ATP_MARKET_DATA_LINE_LIMIT=100

# Storage tiers (SRS-DATA-008/009). SSD is the primary runtime tier; NAS
# is the archival tier. Both are bind-mounted into the Phase 1 stack.
ATP_SSD_DATA_DIR=/var/lib/atp/ssd
ATP_NAS_DATA_DIR=/var/lib/atp/nas

# Durable backtest-result store directory (SRS-BT-009 / SyRS:SYS-79). The
# completed-backtest result store is persisted to a file under this directory;
# SSD/NAS tiering of it is the deferred SRS-DATA-008 owner.
ATP_BACKTEST_RESULTS_DIR=/var/lib/atp/ssd/backtest_results

# Durable market-data store directory (SRS-DATA-016 / SyRS:NFR-R4). The
# idempotent market-data ingestion store is persisted to a file under this
# directory; SSD/NAS tiering of it is the deferred SRS-DATA-008 owner.
ATP_DATA_STORE_DIR=/var/lib/atp/ssd/market_data

# Notification credentials (SRS-NOTIF-001).
ATP_SMTP_API_KEY=placeholder-set-in-environment
ATP_SMS_API_KEY=placeholder-set-in-environment

# Vendor data provider credentials (SRS-DATA-002, SRS-DATA-004).
DATABENTO_API_KEY=placeholder-set-in-environment
SHARADAR_API_KEY=placeholder-set-in-environment

# Strategy resource limits (SyRS SYS-11/57/58, SRS-ORCH-002/003). These are
# the orchestrator's per-strategy memory and CPU caps and the host memory
# safety margin. The compose strategy-runtime template carries the same
# defaults as static labels; the orchestrator selects the live or paper
# profile per strategy at clone time.
ATP_LIVE_STRATEGY_MEM_MB=512
ATP_LIVE_STRATEGY_CPU=0.25
ATP_PAPER_STRATEGY_MEM_MB=300
ATP_PAPER_STRATEGY_CPU=0.10
ATP_HOST_MEMORY_SAFETY_MARGIN_MB=2048
